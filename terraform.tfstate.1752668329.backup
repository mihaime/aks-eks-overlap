            "content": "apiVersion: v1\nkind: Config\nclusters:\n- name: eks-cluster\n  cluster:\n    server: https://95FA68580904C080C689DE5F44F0CF18.gr7.eu-central-1.eks.amazonaws.com\n    certificate-authority-data: \ncontexts:\n- name: eks-cluster\n  context:\n    cluster: eks-cluster\n    user: eks-cluster\ncurrent-context: eks-cluster\nusers:\n- name: eks-cluster\n  user:\n    exec:\n      apiVersion: client.authentication.k8s.io/v1beta1\n      command: aws\n      args:\n        - eks\n        - get-token\n        - --region\n        - eu-central-1\n        - --cluster-name\n        - eks-cluster\n        - --profile\n        - default\n",
